<div class="container mt-4">
  <h1 class="mb-4"><%= @place["name"] %></h1>

  <% if session["user_id"] != nil %>
  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>", class="btn btn-outline-primary">New Entry</a>
  </p>
  <% end %>

  <div class="row g-4">
    <% for entry in @entries %>
      <div class="col-12 col-lg-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= entry["title"] %></h5>
            <p class="card-text">
              <small class="text-muted">
                <%= entry["occurred_on"] %>
              </small>
            </p>
            <% if entry.uploaded_image.attached? %>
              <img src="<%= url_for(entry.uploaded_image) %>" class="img-fluid">
            <% else %>
              <img src="https://images.unsplash.com/photo-1579894963949-95530a650650?q=80&w=1364&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="img-fluid">
            <%end%>
            <p class="card-text"><%= entry["description"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>


  <p>
    <a href="/places", class="btn btn-outline-primary mt-4">Back to All Places</a>
  </p>

</div>


